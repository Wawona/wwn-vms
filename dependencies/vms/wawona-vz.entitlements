<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Required to boot a guest via Virtualization.framework. Ad-hoc codesigning
	  with this entitlement is applied by vz-launcher.nix at first run. This is a
	  non-App-Store capability (spawns VMs) — wawona-vz ships only in the direct
	  (non-MAS) macOS channel, like Mode B.
	-->
	<key>com.apple.security.virtualization</key>
	<true/>
	<!-- Needed on some macOS versions when using virtio-vsock listeners. -->
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
